{
  "version": 10,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 31,
    "patch": 0
  },
  "$comment": "On-device AI across mobile, embedded and edge for PyTorch.",
  "configurePresets": [
    {
      "name": "common",
      "hidden": true,
      "binaryDir": "${sourceDir}/cmake-out",
      "generator": "Unix Makefiles"
    },
    {
      "name": "macos-arm64",
      "inherits": ["common"],
      "generator": "Xcode",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/third-party/ios-cmake/ios.toolchain.cmake",
        "EXECUTORCH_BUILD_PRESET_FILE": "${sourceDir}/tools/cmake/preset/macos-arm64.cmake",
        "PLATFORM": "MAC_ARM64",
        "DEPLOYMENT_TARGET": "10.15"
      },
      "condition": {
        "lhs": "${hostSystemName}",
        "type": "equals",
        "rhs": "Darwin"
      }
    },
    {
      "name": "pybind-macos",
      "inherits": ["common"],
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/third-party/ios-cmake/ios.toolchain.cmake",
        "EXECUTORCH_BUILD_PRESET_FILE": "${sourceDir}/tools/cmake/preset/pybind-macos.cmake",
        "PLATFORM": "MAC_ARM64",
        "DEPLOYMENT_TARGET": "10.15"
      },
      "condition": {
        "lhs": "${hostSystemName}",
        "type": "equals",
        "rhs": "Darwin"
      }
    },
    {
      "name": "pybind-linux",
      "inherits": ["common"],
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Linux",
        "EXECUTORCH_BUILD_PRESET_FILE": "${sourceDir}/tools/cmake/preset/pybind-linux.cmake"
      },
      "condition": {
        "lhs": "${hostSystemName}",
        "type": "equals",
        "rhs": "Linux"
      }
    }
  ]
}
