{
    "version": 6,
    "configurePresets": [
        {
            "name": "voxtral-realtime-base",
            "hidden": true,
            "binaryDir": "${sourceDir}/../../../cmake-out/examples/models/voxtral_realtime",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_FIND_ROOT_PATH": "${sourceDir}/../../../cmake-out",
                "CMAKE_PREFIX_PATH": "${sourceDir}/../../../cmake-out"
            }
        },
        {
            "name": "voxtral-realtime-cpu",
            "displayName": "Voxtral Realtime runner (CPU)",
            "inherits": [
                "voxtral-realtime-base"
            ]
        },
        {
            "name": "voxtral-realtime-metal",
            "displayName": "Voxtral Realtime runner (Metal)",
            "inherits": [
                "voxtral-realtime-base"
            ],
            "cacheVariables": {
                "EXECUTORCH_BUILD_METAL": "ON"
            },
            "condition": {
                "lhs": "${hostSystemName}",
                "type": "equals",
                "rhs": "Darwin"
            }
        },
        {
            "name": "voxtral-realtime-cuda",
            "displayName": "Voxtral Realtime runner (CUDA)",
            "inherits": [
                "voxtral-realtime-base"
            ],
            "cacheVariables": {
                "EXECUTORCH_BUILD_CUDA": "ON"
            },
            "condition": {
                "type": "inList",
                "string": "${hostSystemName}",
                "list": [
                    "Linux",
                    "Windows"
                ]
            }
        }
    ],
    "buildPresets": [
        {
            "name": "voxtral-realtime-cpu",
            "displayName": "Build Voxtral Realtime runner (CPU)",
            "configurePreset": "voxtral-realtime-cpu",
            "configuration": "Release",
            "targets": [
                "voxtral_realtime_runner"
            ]
        },
        {
            "name": "voxtral-realtime-metal",
            "displayName": "Build Voxtral Realtime runner (Metal)",
            "configurePreset": "voxtral-realtime-metal",
            "configuration": "Release",
            "targets": [
                "voxtral_realtime_runner"
            ]
        },
        {
            "name": "voxtral-realtime-cuda",
            "displayName": "Build Voxtral Realtime runner (CUDA)",
            "configuration": "Release",
            "configurePreset": "voxtral-realtime-cuda",
            "targets": [
                "voxtral_realtime_runner"
            ]
        }
    ],
    "workflowPresets": [
        {
            "name": "voxtral-realtime-cpu",
            "displayName": "Configure and build Voxtral Realtime runner (CPU)",
            "steps": [
                {
                    "type": "configure",
                    "name": "voxtral-realtime-cpu"
                },
                {
                    "type": "build",
                    "name": "voxtral-realtime-cpu"
                }
            ]
        },
        {
            "name": "voxtral-realtime-metal",
            "displayName": "Configure and build Voxtral Realtime runner (Metal)",
            "steps": [
                {
                    "type": "configure",
                    "name": "voxtral-realtime-metal"
                },
                {
                    "type": "build",
                    "name": "voxtral-realtime-metal"
                }
            ]
        },
        {
            "name": "voxtral-realtime-cuda",
            "displayName": "Configure and build Voxtral Realtime runner (CUDA)",
            "steps": [
                {
                    "type": "configure",
                    "name": "voxtral-realtime-cuda"
                },
                {
                    "type": "build",
                    "name": "voxtral-realtime-cuda"
                }
            ]
        }
    ]
}