{
    "version": 6,
    "configurePresets": [
        {
            "name": "sortformer-base",
            "hidden": true,
            "binaryDir": "${sourceDir}/../../../cmake-out/examples/models/sortformer",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_FIND_ROOT_PATH": "${sourceDir}/../../../cmake-out",
                "CMAKE_PREFIX_PATH": "${sourceDir}/../../../cmake-out"
            }
        },
        {
            "name": "sortformer-cpu",
            "displayName": "Sortformer runner (CPU)",
            "inherits": ["sortformer-base"]
        },
        {
            "name": "sortformer-cuda",
            "displayName": "Sortformer runner (CUDA)",
            "inherits": ["sortformer-base"],
            "cacheVariables": {
                "EXECUTORCH_BUILD_CUDA": "ON"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "sortformer-cuda-debug",
            "displayName": "Sortformer runner (CUDA Debug)",
            "inherits": ["sortformer-base"],
            "cacheVariables": {
                "EXECUTORCH_BUILD_CUDA": "ON",
                "CMAKE_BUILD_TYPE": "Debug"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "sortformer-cpu",
            "displayName": "Build Sortformer runner (CPU)",
            "configurePreset": "sortformer-cpu",
            "configuration": "Release",
            "targets": ["sortformer_runner"]
        },
        {
            "name": "sortformer-cuda",
            "displayName": "Build Sortformer runner (CUDA)",
            "configurePreset": "sortformer-cuda",
            "configuration": "Release",
            "targets": ["sortformer_runner"]
        },
        {
            "name": "sortformer-cuda-debug",
            "displayName": "Build Sortformer runner (CUDA Debug)",
            "configurePreset": "sortformer-cuda-debug",
            "targets": ["sortformer_runner"]
        }
    ],
    "workflowPresets": [
        {
            "name": "sortformer-cpu",
            "displayName": "Configure and build Sortformer runner (CPU)",
            "steps": [
                {
                    "type": "configure",
                    "name": "sortformer-cpu"
                },
                {
                    "type": "build",
                    "name": "sortformer-cpu"
                }
            ]
        },
        {
            "name": "sortformer-cuda",
            "displayName": "Configure and build Sortformer runner (CUDA)",
            "steps": [
                {
                    "type": "configure",
                    "name": "sortformer-cuda"
                },
                {
                    "type": "build",
                    "name": "sortformer-cuda"
                }
            ]
        },
        {
            "name": "sortformer-cuda-debug",
            "displayName": "Configure and build Sortformer runner (CUDA Debug)",
            "steps": [
                {
                    "type": "configure",
                    "name": "sortformer-cuda-debug"
                },
                {
                    "type": "build",
                    "name": "sortformer-cuda-debug"
                }
            ]
        }
    ]
}
