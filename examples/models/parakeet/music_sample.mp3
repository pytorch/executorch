  "review": [
    {
      "@type": "Review",
      "author": {
        "@type": "Person",
        "name": "Manfred Grandis"
      },
      "datePublished": "2025-06-10",
      "reviewBody": "Hervorragende Qualität, sehr netter Kontakt. Ich bestelle schon seit einigen Jahren Griffmaterial für meine selbst hergestellten Messer. Die Qualität ist hervorragend - wasserdicht, lebensmittelecht, verzieht sich nicht. Messer mit diesen Griffhölzern sind immer ein Blickfang. Auf jeden Fall sehr empfehlenswert! Frederick ist supernett und antwortet immer gleich. Sonderwünsche werden erfüllt.",
      "reviewRating": {
        "@type": "Rating",
        "ratingValue": 5
      }
    },
    {
      "@type": "Review",
      "author": {
        "@type": "Person",
        "name": "Martin Ruechel"
      },
      "datePublished": "2025-08-15",
      "reviewBody": "Mein Hobby ist Messerbau und da verwende ich das stabilisierte Holz von ACRYHOLZ. Was soll ich sagen? :-) Einfach geil. Das erste Messer ist schon ein paar Jahre her, Griff sieht immer noch geil aus und das Holz ist sehr schön zu verarbeiten! Ich verwende mittlerweile nur noch dieses Holz, da die Messergriffe deutlich beständiger sind, als mit normalem Holz und die Optik verzaubert.",
      "reviewRating": {
        "@type": "Rating",
        "ratingValue": 5
      }
    }
  ]
}
</script>

<!-- FAQ -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was ist stabilisiertes Holz?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Stabilisiertes Holz von ACRYHOLZ ist natürliches Holz, das durch ein spezielles Vakuum-Druck-Verfahren mit transparentem oder farbigem Acrylharz vollständig durchtränkt wurde. Durch diese Imprägnierung entsteht ein formstabiles, sehr hartes und langlebiges Material, das wasser-, chemikalien- und verzugsresistent sowie lebensmittelecht ist. Das Ergebnis verbindet die natürliche Holzoptik mit den Vorteilen eines widerstandsfähigen, modernen Werkstoffs und eignet sich besonders für hochwertige Messergriffe, Schmuck, Designobjekte und ähnliche Anwendungen."
      }
    },
    {
      "@type": "Question",
      "name": "Wie lange dauert die Auftragsstabilisierung?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Auftragsstabilisierung dauert bei ACRYHOLZ ca. 5 Werktage ab Holzeingang."
      }
    },
    {
      "@type": "Question",
      "name": "Welche Holzarten eignen sich?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Besonders geeignet sind Ahorn, Pappel, Birke, Buche, Esche, Kastanie, Linde, Ulme und weitere Weichhölzer."
      }
    },
    {
      "@type": "Question",
      "name": "Bietet ACRYHOLZ Farbstabilisierung an?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ja – wir bieten Uni-, Bi- und Tri-Color-Stabilisierung im PUQ-Verfahren an."
      }
    }
  ]
}
</script>

